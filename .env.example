# Supabase connection — copy this file to ".env.local" and fill in your values.
# Find both values in your Supabase project: Settings → API.
# The anon key is safe to expose in the browser; access is protected by
# Row Level Security (see supabase/schema.sql).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Finnhub stock data (https://finnhub.io) — free tier, for live stock
# names and prices. Optional: leave blank to disable the live-price features.
VITE_FINNHUB_API_KEY=YOUR-FINNHUB-KEY

# Set to "true" to show the sign-up option on the login screen.
# Leave unset/anything else to keep new-member registration closed.
# (Also disable sign-ups in the Supabase dashboard for real enforcement.)
VITE_ALLOW_SIGNUP=false
